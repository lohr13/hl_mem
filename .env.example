# === LLM 提取 — 百炼 Coding Plan ===
# Coding Plan AK 只能打 coding.dashscope 端点
LLM_API_KEY=sk-sp-xxx
LLM_BASE_URL=https://coding.dashscope.aliyuncs.com/v1
LLM_MODEL=glm-5.2
LLM_TIMEOUT=30

# === Embedding — 百炼通用 AK ===
# 通用 AK 只能打 compatible-mode 端点，与 Coding Plan AK 互不通用
EMBEDDING_API_KEY=sk-e72xxx
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_DIM=2048
EMBEDDING_CONNECT_TIMEOUT=5
EMBEDDING_READ_TIMEOUT=30
EMBEDDING_MAX_ATTEMPTS=3

# === Reranker — 百炼通用 AK（可选，off 则跳过）===
HL_MEM_RERANKER=on
RERANKER_API_KEY=sk-e72xxx
RERANKER_BASE_URL=https://dashscope.aliyuncs.com
RERANKER_MODEL=gte-rerank-v2

# === 运行模式 ===
HL_MEM_ENV=dev                    # dev | production（production 强制 real embedder + reranker）
HL_MEM_DB_PATH=var/hl_mem.db
HL_MEM_EXTRACTOR=llm              # fake | llm（测试用 fake）
HL_MEM_EMBEDDER=real              # fake | real（测试用 fake）

# === 去重 / 冲突阈值 ===
HL_MEM_DEDUP_THRESHOLD=0.82

# === Worker ===
HL_MEM_WORKER_POLL_INTERVAL=2.0
HL_MEM_WORKER_LEASE_MINUTES=5
HL_MEM_WORKER_MAINTENANCE_INTERVAL=600

# === 召回 ===
HL_MEM_RECALL_DEFAULT_LIMIT=20
HL_MEM_RECALL_VECTOR_SCAN_LIMIT=200

# === 数据保留 ===
HL_MEM_RETENTION_DAYS=30
HL_MEM_STATE_TRANSIENT_TTL_DAYS=7
HL_MEM_STATE_TEST_SUITE_TTL_DAYS=7

# === Token 预算 ===
HL_MEM_DAILY_TOKEN_LIMIT=10000000000
